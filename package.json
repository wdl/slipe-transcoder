{
  "name": "slipe-transcoder",
  "version": "2.0.0",
  "private": true,
  "description": "Serverless chunked-parallel video transcoder on AWS Lambda — splits input into 10s chunks, fans out to N parallel Lambdas with bundled ffmpeg, merges, and delivers via signed webhook.",
  "type": "module",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "homepage": "https://github.com/owner/slipe-transcoder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owner/slipe-transcoder.git"
  },
  "bugs": {
    "url": "https://github.com/owner/slipe-transcoder/issues"
  },
  "keywords": [
    "aws",
    "lambda",
    "video",
    "transcoder",
    "ffmpeg",
    "serverless",
    "cdk",
    "s3",
    "dynamodb"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "docker:build": "docker build -t slipe-transcoder:local -f docker/Dockerfile .",
    "docker:smoke": "docker run --rm slipe-transcoder:local /usr/local/bin/ffmpeg -version",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "cdk:deploy": "cdk deploy --require-approval never",
    "cdk:destroy": "cdk destroy --force",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run cdk:synth"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.10.0",
    "@aws-lambda-powertools/metrics": "^2.10.0",
    "@aws-lambda-powertools/tracer": "^2.10.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@aws-sdk/s3-presigned-post": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@aws-sdk/util-dynamodb": "^3.700.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.16.5",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "aws-cdk": "^2.1123.0",
    "aws-cdk-lib": "^2.255.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^4.0.0",
    "constructs": "^10.4.2",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
